# Normalize line endings for all text files in the repository.
* text=auto eol=lf

# Windows command scripts should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Unix shell scripts and Maven wrapper should use LF.
*.sh text eol=lf
backend/mvnw text eol=lf

# Common text-based project files should stay LF.
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.md text eol=lf

# Binary assets must not be line-normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.keystore binary